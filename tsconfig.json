{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "es2015",
    "module": "es2015",
    "outDir": "./dist/src",
    "strictNullChecks": false,
    "moduleResolution": "node",
    "traceResolution": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/*.ts"
  ]
}